  "pipeline_id": "90617587-a73d-4e4f-8813-fafc67fe03d9",
  "name": "Concept Prescreen Pipeline",
  "version": "1.0",
  "created_at": "2026-03-31T00:00:00Z",
  "updated_at": "2026-03-31T00:00:00Z",
  "metadata": {
    "description": "Filters respondent data and generates product concepts via LLM. Use for rapid concept ideation workflows.",
    "tags": ["concept-testing", "generation", "llm", "ideation"],
    "author": "system"
  },
  "nodes": [
    {
      "node_id": "6371d17a-c304-43aa-91be-004d208a09c4",
      "block_type": "source",
      "block_implementation": "csv_source",
      "label": "Load CSV Data",
      "position": {"x": 100, "y": 200},
      "config": {
        "csv_data": "respondent_id,age,gender,region,pain_points\nR001,28,Female,North,Back pain from sitting\nR002,35,Male,South,Lack of storage\nR003,42,Female,West,Desk too small\nR004,31,Male,North,Poor lighting\nR005,39,Female,East,Uncomfortable chair",
        "delimiter": ","
      },
      "input_schema": [],
      "output_schema": ["respondent_collection"]
    },
    {
      "node_id": "e66611c3-839d-4563-a667-5f8d328ce8dc",
      "block_type": "transform",
      "block_implementation": "filter_transform",
      "label": "Filter Age 25-40",
      "position": {"x": 350, "y": 200},
      "config": {
        "column": "age",
        "operator": "gte",
        "value": 25
      },
      "input_schema": ["respondent_collection"],
      "output_schema": ["respondent_collection"]
    },
    {
      "node_id": "30b81a4c-5fa3-4828-90c5-9a7627c44321",
      "block_type": "generation",
      "block_implementation": "concept_drafter",
      "label": "Generate Concepts",
      "position": {"x": 600, "y": 200},
      "config": {
        "prompt_template": "Generate product concepts for home office furniture based on these customer needs: {input}",
        "n_concepts": 3,
        "model": "claude-sonnet-4-6",
        "temperature": 0.7
      },
      "input_schema": ["respondent_collection"],
      "output_schema": ["concept_brief_set"]
    },
    {
      "node_id": "34d6010d-474d-4a3e-8231-57713a78fdcf",
      "block_type": "sink",
      "block_implementation": "json_sink",
      "label": "Save Concepts",
      "position": {"x": 850, "y": 200},
      "config": {
        "output_key": "generated_concepts",
        "pretty_print": true
      },
      "input_schema": ["concept_brief_set"],
      "output_schema": []
    }
  ],
